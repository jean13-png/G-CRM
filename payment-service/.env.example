# G-CRM Payment Service — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# FedaPay (Live)
FEDAPAY_SECRET_KEY=sk_live_YOUR_FEDAPAY_SECRET_KEY
FEDAPAY_PUBLIC_KEY=pk_live_YOUR_FEDAPAY_PUBLIC_KEY

# URL publique de ce service (après déploiement sur Render)
# Exemple: https://g-crm-payment-service.onrender.com
PAYMENT_SERVICE_URL=https://g-crm-payment-service.onrender.com

# Clé API interne (partagée avec l'app Flutter)
INTERNAL_API_KEY=your_secure_internal_key_here

# Firebase Admin SDK — JSON du compte de service
# Récupérer depuis Firebase Console > Paramètres > Comptes de service > Générer une clé privée
# Puis copier le contenu JSON en une seule ligne
FIREBASE_SERVICE_ACCOUNT_JSON=

# Port d'écoute (Render utilise PORT automatiquement)
PORT=3002
