rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isEnterpriseUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/enterprises/$(request.auth.uid));
    }

    function isAgentUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/agents/$(request.auth.uid));
    }

    function currentEnterpriseId() {
      return isEnterpriseUser()
        ? request.auth.uid
        : (isAgentUser()
          ? get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.enterpriseId
          : null);
    }

    function belongsToEnterprise(enterpriseId) {
      return isSignedIn() &&
        enterpriseId != null &&
        currentEnterpriseId() == enterpriseId;
    }

    function canReadResource(resourceData) {
      return belongsToEnterprise(resourceData.enterpriseId);
    }

    function canWriteResource(requestData) {
      return belongsToEnterprise(requestData.enterpriseId);
    }

    match /enterprises/{enterpriseId} {
      allow read: if belongsToEnterprise(enterpriseId);
      allow write: if isSignedIn() && request.auth.uid == enterpriseId;
    }

    match /agents/{agentId} {
      allow read: if canReadResource(resource.data);
      allow create: if canWriteResource(request.resource.data) &&
        isEnterpriseUser() &&
        request.auth.uid == request.resource.data.enterpriseId;
      allow update: if canReadResource(resource.data) &&
        canWriteResource(request.resource.data) &&
        (isEnterpriseUser() || request.auth.uid == agentId);
      allow delete: if canReadResource(resource.data) &&
        isEnterpriseUser() &&
        request.auth.uid == resource.data.enterpriseId;
    }

    match /prospects/{prospectId} {
      allow read: if canReadResource(resource.data);
      allow create: if canWriteResource(request.resource.data);
      allow update: if canReadResource(resource.data) &&
        canWriteResource(request.resource.data);
      allow delete: if canReadResource(resource.data);
    }

    match /tasks/{taskId} {
      allow read: if canReadResource(resource.data);
      allow create: if canWriteResource(request.resource.data);
      allow update: if canReadResource(resource.data) &&
        canWriteResource(request.resource.data);
      allow delete: if canReadResource(resource.data);
    }

    match /chatMessages/{messageId} {
      allow read: if canReadResource(resource.data);
      allow create: if canWriteResource(request.resource.data);
      allow update: if canReadResource(resource.data) &&
        canWriteResource(request.resource.data);
      allow delete: if canReadResource(resource.data);
    }

    match /whatsapp_queue/{messageId} {
      allow read: if canReadResource(resource.data);
      allow create: if canWriteResource(request.resource.data);
      allow update: if canReadResource(resource.data) &&
        canWriteResource(request.resource.data);
      allow delete: if canReadResource(resource.data);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.targetUserId;
      allow create: if isSignedIn() &&
        request.resource.data.targetUserId != null &&
        request.resource.data.targetUserId is string;
      allow update: if isSignedIn() && request.auth.uid == resource.data.targetUserId;
      allow delete: if false;
    }
  }
}
